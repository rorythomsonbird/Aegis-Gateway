# Copy this to .env and fill in values as needed.
# None of these are required — the gateway runs fully on the mock LLM without them.

# ── LLM (optional — uses mock if not set) ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ── Security thresholds ───────────────────────────────────────────────────────
INJECTION_THRESHOLD=0.5      # 0–1, lower = stricter
TRUST_THRESHOLD=0.5          # documents below this score are dropped

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_CAPACITY=10       # max requests per window
RATE_LIMIT_WINDOW=60         # window size in seconds
FUZZ_THRESHOLD=0.85          # similarity ratio for fuzzing detection (0–1)

# ── RAG ───────────────────────────────────────────────────────────────────────
TOP_K=3                      # documents to retrieve per query
EMBED_MODEL=all-MiniLM-L6-v2

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=logs/requests.db
